rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (First Rule Block)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'halilovramazan394@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      
      allow create: if isEmailVerified() 
        && incoming().id == bookingId 
        && incoming().userEmail == request.auth.token.email 
        && incoming().userId == request.auth.uid
        && incoming().status == 'active'
        && incoming().hoursCount is number 
        && incoming().hoursCount > 0
        && incoming().totalPrice == incoming().hoursCount * 2000
        && incoming().timeSlots is list
        && incoming().timeSlots.size() > 0;

      allow update: if isSignedIn() && (
        isAdmin() ||
        existing().userId == request.auth.uid ||
        existing().userEmail == request.auth.token.email ||
        (existing().userEmail != null && request.auth.token.email != null && existing().userEmail.lowerAscii() == request.auth.token.email.lowerAscii())
      );

      allow delete: if isAdmin();
    }

    // Blocked dates collection
    match /blockedDates/{dateId} {
      allow read: if true; // Anyone can read blocked dates to show green/red on the booking calendar
      allow write: if isAdmin();
    }
  }
}
